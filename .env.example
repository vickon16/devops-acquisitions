# Copy this file to .env and fill in the values.
# For Docker dev, also copy to .env.development

# Server
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# App
JWT_SECRET=your_jwt_secret_here

# ── Database ──────────────────────────────────────────────────────────────────
# Production: use your Neon Cloud connection string
DATABASE_URL=""

# ── Neon Local proxy (dev only) ───────────────────────────────────────────────
NEON_API_KEY=your_neon_api_key
NEON_PROJECT_ID=your_neon_project_id
PARENT_BRANCH_ID=br-your-parent-branch-id
NEON_DB_PASSWORD=your_neon_db_role_password